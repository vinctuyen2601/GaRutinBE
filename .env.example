NODE_ENV=development
PORT=4001

# PostgreSQL (Neon hoặc local)
DATABASE_URL=postgresql://user:pass@host/garutin

# JWT
JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRES_IN=30d

# Cloudflare R2
R2_ENDPOINT=https://xxxx.r2.cloudflarestorage.com
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=garutin
R2_PUBLIC_URL=https://cdn.garutin.vn

# Admin seed account (chạy khi migration:run lần đầu)
ADMIN_EMAIL=admin@garutin.vn
ADMIN_PASSWORD=Admin@123456

# CORS origins (cách nhau bởi dấu phẩy)
CMS_URL=http://localhost:5174
WEB_URL=http://localhost:3000
